generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  STUDENT
  COMPANY
  ADMIN
}

enum SwipeDirection {
  LEFT
  RIGHT
  SUPER
}

enum MatchStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum ApplicationStatus {
  PENDING
  VIEWED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

// ============================================
// AUTH & USERS
// ============================================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole
  isVerified   Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  studentProfile StudentProfile?
  companyProfile CompanyProfile?
  refreshTokens  RefreshToken[]
  sentMessages   Message[]       @relation("SentMessages")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================
// STUDENT
// ============================================

model StudentProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime
  canton      String
  city        String
  bio                 String?  @db.Text
  motivationLetter    String?  @db.Text  // General motivation letter text (onboarding)
  motivationLetterUrl String?            // Uploaded PDF/image URL (Supabase storage)
  profilePhoto        String?

  // OCEAN personality scores (0.0 - 1.0)
  oceanOpenness          Float @default(0.5)
  oceanConscientiousness Float @default(0.5)
  oceanExtraversion      Float @default(0.5)
  oceanAgreeableness     Float @default(0.5)
  oceanNeuroticism       Float @default(0.5)

  // RIASEC career interest scores (0.0 - 1.0)
  riasecRealistic     Float @default(0)
  riasecInvestigative Float @default(0)
  riasecArtistic      Float @default(0)
  riasecSocial        Float @default(0)
  riasecEnterprising  Float @default(0)
  riasecConventional  Float @default(0)

  quizCompletedAt DateTime?

  // Culture preference scores (0-100, nullable until culture quiz completed)
  cultureHierarchyFocus      Int?  // 0=Autonomy, 100=Obedience
  culturePunctualityRigidity Int?  // 0=Flexible, 100=Strict
  cultureResilienceGrit      Int?  // 0=Variety, 100=Routine/Endurance
  cultureSocialEnvironment   Int?  // 0=Solo, 100=Team
  cultureErrorCulture        Int?  // 0=Fast/Fail, 100=Precision/Safety
  cultureClientFacing        Int?  // 0=Back-office, 100=Front-stage
  cultureDigitalAffinity     Int?  // 0=Analog/Hand, 100=Digital/Screen
  culturePrideFocus          Int?  // 0=Speed/Output, 100=Quality/Masterpiece
  cultureQuizCompletedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  desiredFields StudentDesiredField[]
  swipes         Swipe[]
  matches        Match[]
  applications   Application[]
  grades         StudentGrade[]
  favoriteBerufe StudentFavoriteBeruf[]

  @@map("student_profiles")
}

model StudentDesiredField {
  id        String @id @default(cuid())
  studentId String
  field     String
  priority  Int    @default(0)

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, field])
  @@map("student_desired_fields")
}

// ============================================
// COMPANY
// ============================================

model CompanyProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  companyName       String
  description       String  @db.Text
  industry          String
  companySize       String
  website           String?
  logoUrl           String?
  videoUrl          String?
  canton            String
  city              String
  address           String?
  contactPersonName String
  contactPersonRole String?
  isVerified        Boolean @default(false)

  // Culture scores (0-100, nullable)
  cultureHierarchyFocus      Int?
  culturePunctualityRigidity Int?
  cultureResilienceGrit      Int?
  cultureSocialEnvironment   Int?
  cultureErrorCulture        Int?
  cultureClientFacing        Int?
  cultureDigitalAffinity     Int?
  culturePrideFocus          Int?
  culturePresetId            String?

  // Dealbreaker flags (true = hard filter in matching)
  dealbreakerHierarchyFocus      Boolean @default(false)
  dealbreakerPunctualityRigidity Boolean @default(false)
  dealbreakerResilienceGrit      Boolean @default(false)
  dealbreakerSocialEnvironment   Boolean @default(false)
  dealbreakerErrorCulture        Boolean @default(false)
  dealbreakerClientFacing        Boolean @default(false)
  dealbreakerDigitalAffinity     Boolean @default(false)
  dealbreakerPrideFocus          Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings      Listing[]
  photos        CompanyPhoto[]
  links         CompanyLink[]
  culturePreset CompanyCulturePreset? @relation(fields: [culturePresetId], references: [id])

  @@map("company_profiles")
}

model CompanyPhoto {
  id        String   @id @default(cuid())
  companyId String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_photos")
}

model CompanyLink {
  id        String   @id @default(cuid())
  companyId String
  label     String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_links")
}

// ============================================
// CULTURE PRESETS
// ============================================

model CompanyCulturePreset {
  id                  String @id @default(cuid())
  name                String @unique // e.g. "Schreiner/in", "Bank", "Detailhandel"
  hierarchyFocus      Int    // 0-100
  punctualityRigidity Int
  resilienceGrit      Int
  socialEnvironment   Int
  errorCulture        Int
  clientFacing        Int
  digitalAffinity     Int
  prideFocus          Int
  createdAt           DateTime @default(now())

  companies CompanyProfile[]

  @@map("company_culture_presets")
}

// ============================================
// LISTINGS
// ============================================

model Listing {
  id          String @id @default(cuid())
  companyId   String
  title       String
  description String @db.Text
  field       String
  berufsfeld  String @default("")

  requiredSchoolLevel String?
  requiredLanguages   String[]  @default(["de"])
  startDate           DateTime?
  durationYears       Int       @default(3)
  spotsAvailable      Int       @default(1)

  // Ideal personality fit (set by company, optional)
  idealOceanOpenness          Float?
  idealOceanConscientiousness Float?
  idealOceanExtraversion      Float?
  idealOceanAgreeableness     Float?
  idealOceanNeuroticism       Float?
  idealRiasecRealistic        Float?
  idealRiasecInvestigative    Float?
  idealRiasecArtistic         Float?
  idealRiasecSocial           Float?
  idealRiasecEnterprising     Float?
  idealRiasecConventional     Float?

  cards              Json     @default("[]")
  motivationQuestions Json     @default("[]")  // [{question: string, placeholder?: string}]

  canton   String
  city     String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      CompanyProfile? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  swipes       Swipe[]
  matches      Match[]
  applications Application[]

  @@index([companyId])
  @@index([field])
  @@index([canton])
  @@index([isActive])
  @@map("listings")
}

// ============================================
// SWIPES & MATCHING
// ============================================

model Swipe {
  id        String         @id @default(cuid())
  studentId String
  listingId String
  direction SwipeDirection
  createdAt DateTime       @default(now())

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  listing Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([studentId, listingId])
  @@index([studentId])
  @@index([listingId])
  @@map("swipes")
}

model Match {
  id                 String      @id @default(cuid())
  studentId          String
  listingId          String
  compatibilityScore Float
  status             MatchStatus @default(ACTIVE)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  listing     Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  messages    Message[]
  application Application?

  @@unique([studentId, listingId])
  @@index([studentId])
  @@index([listingId])
  @@map("matches")
}

// ============================================
// MESSAGING
// ============================================

model Message {
  id        String      @id @default(cuid())
  matchId   String
  senderId  String
  content   String      @db.Text
  type      MessageType @default(TEXT)
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())

  match  Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender User  @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([senderId])
  @@map("messages")
}

// ============================================
// APPLICATIONS
// ============================================

model Application {
  id        String            @id @default(cuid())
  studentId String
  listingId String
  matchId   String            @unique
  status    ApplicationStatus @default(PENDING)
  notes     String?           @db.Text
  timeline  Json              @default("[]")

  // Bewerbung content (customized per job by student)
  motivationAnswers    Json     @default("[]")  // [{question: string, answer: string}]
  verfuegbarkeit       String?
  relevanteErfahrungen Json     @default("[]")
  fragenAnBetrieb      String?  @db.Text
  schnupperlehreWunsch Boolean  @default(false)

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  listing Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  match   Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([studentId, listingId])
  @@index([studentId])
  @@index([listingId])
  @@map("applications")
}

// ============================================
// STUDENT GRADES (Zeugnis, Multicheck, etc.)
// ============================================

model StudentGrade {
  id        String @id @default(cuid())
  studentId String

  // Document metadata
  documentType String // 'zeugnis' | 'multicheck' | 'basic_check' | 'stellwerk'
  entryMethod  String // 'scan' | 'manual'

  // Zeugnis-specific
  canton     String?
  niveau     String?  // 'Sek A', 'Sek B', 'Sek C', 'Bezirksschule'
  semester   Int?     // 1 or 2
  schoolYear String?  // '2025/2026'

  // Multicheck/Stellwerk-specific
  testVariant String?   // 'Multicheck ICT', 'Basic-Check', 'Stellwerk'
  testDate    DateTime?

  // Actual grades (flexible JSONB)
  grades Json
  // Zeugnis: {"mathematik": 5.5, "deutsch": 5.0, ...}
  // Multicheck: {"schulisches_wissen": {"mathematik": 72}, "potenzial": {"logisches_denken": 68}}

  // Verification
  isVerified         Boolean   @default(false)
  verifiedAt         DateTime?
  verificationMethod String    @default("self")

  // OCR metadata (scan entries only)
  ocrConfidence          Float?
  ocrLowConfidenceFields String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([documentType])
  @@map("student_grades")
}

// ============================================
// SUPABASE-NATIVE TABLES (now Prisma-managed)
// Reference data + imported apprenticeship listings
// ============================================

model Beruf {
  code                           String   @id
  nameDe                         String   @map("name_de")
  nameFr                         String?  @map("name_fr")
  nameIt                         String?  @map("name_it")
  field                          String
  educationType                  String   @default("EFZ") @map("education_type")
  descriptionDe                  String?  @map("description_de")
  descriptionFr                  String?  @map("description_fr")
  descriptionIt                  String?  @map("description_it")
  personalityFit                 Json     @default("{}") @map("personality_fit")
  createdAt                      DateTime @default(now()) @map("created_at")
  durationYears                  Int?     @map("duration_years")
  hollandCode                    String?  @map("holland_code")
  onetSocCode                    String?  @map("onet_soc_code")
  bbId                           String?  @map("bb_id")
  swissdocId                     String?  @map("swissdoc_id")
  lenaRelevant                   Boolean  @default(true) @map("lena_relevant")
  dataSource                     String   @default("manual") @map("data_source")
  anforderungMathematik          Int?     @map("anforderung_mathematik")
  anforderungSchulsprache        Int?     @map("anforderung_schulsprache")
  anforderungNaturwissenschaften Int?     @map("anforderung_naturwissenschaften")
  anforderungFremdsprachen       Int?     @map("anforderung_fremdsprachen")
  lohnLehrjahre                  Json?    @map("lohn_lehrjahre")

  lehrstellen          Lehrstelle[]
  favoriteByStudents   StudentFavoriteBeruf[]
  berufsschuleMappings BerufsschuleBerufMapping[]

  @@map("berufe")
}

model ImportedCompany {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authUserId                 String?   @unique @map("auth_user_id") @db.Uuid
  companyName                String    @map("company_name")
  industry                   String
  canton                     String
  city                       String
  postalCode                 String?   @map("postal_code")
  address                    String?
  websiteUrl                 String?   @map("website_url")
  description                String?
  logoUrl                    String?   @map("logo_url")
  videoUrl                   String?   @map("video_url")
  companySize                String?   @map("company_size")
  cultureTags                Json      @default("[]") @map("culture_tags")
  cultureDescription         String?   @map("culture_description")
  contactPerson              String?   @map("contact_person")
  contactEmail               String    @map("contact_email")
  contactPhone               String?   @map("contact_phone")
  verified                   Boolean   @default(false)
  premium                    Boolean   @default(false)
  premiumExpiresAt           DateTime? @map("premium_expires_at")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @default(now()) @map("updated_at")
  dataSource                 String    @default("manual") @map("data_source")
  lenaCompanyKey             String?   @unique @map("lena_company_key")
  contactPersonName          String?   @map("contact_person_name")
  contactPersonRole          String?   @map("contact_person_role")
  cultureHierarchyFocus      Int?      @map("culture_hierarchy_focus")
  culturePunctualityRigidity Int?      @map("culture_punctuality_rigidity")
  cultureResilienceGrit      Int?      @map("culture_resilience_grit")
  cultureSocialEnvironment   Int?      @map("culture_social_environment")
  cultureErrorCulture        Int?      @map("culture_error_culture")
  cultureClientFacing        Int?      @map("culture_client_facing")
  cultureDigitalAffinity     Int?      @map("culture_digital_affinity")
  culturePrideFocus          Int?      @map("culture_pride_focus")

  lehrstellen Lehrstelle[]

  @@map("companies")
}

model Lehrstelle {
  id                             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId                      String    @map("company_id") @db.Uuid
  berufCode                      String    @map("beruf_code")
  title                          String
  description                    String
  requirements                   Json      @default("[]")
  idealCandidate                 Json      @default("{}") @map("ideal_candidate")
  educationType                  String    @default("EFZ") @map("education_type")
  startDate                      DateTime? @map("start_date")
  durationYears                  Int       @default(3) @map("duration_years")
  canton                         String
  city                           String
  postalCode                     String?   @map("postal_code")
  videoUrl                       String?   @map("video_url")
  photos                         Json      @default("[]")
  cultureDescription             String?   @map("culture_description")
  lenaReferenceId                String?   @map("lena_reference_id")
  status                         String    @default("active")
  positionsAvailable             Int       @default(1) @map("positions_available")
  dailyViewsCount                Int       @default(0) @map("daily_views_count")
  totalSwipesRight               Int       @default(0) @map("total_swipes_right")
  totalSwipesLeft                Int       @default(0) @map("total_swipes_left")
  createdAt                      DateTime  @default(now()) @map("created_at")
  updatedAt                      DateTime  @default(now()) @map("updated_at")
  berufsschuleCanton             String?   @map("berufsschule_canton")
  workplaceAddress               String?   @map("workplace_address")
  lat                            Float?
  lng                            Float?
  berufsschuleId                 String?   @map("berufsschule_id") @db.Uuid
  berufsschuleDays               String?   @map("berufsschule_days")
  berufCategory                  String?   @map("beruf_category")
  dataSource                     String    @default("manual") @map("data_source")
  idealOceanOpenness             Float?    @map("ideal_ocean_openness")
  idealOceanConscientiousness    Float?    @map("ideal_ocean_conscientiousness")
  idealOceanExtraversion         Float?    @map("ideal_ocean_extraversion")
  idealOceanAgreeableness        Float?    @map("ideal_ocean_agreeableness")
  idealOceanNeuroticism          Float?    @map("ideal_ocean_neuroticism")
  idealRiasecRealistic           Float?    @map("ideal_riasec_realistic")
  idealRiasecInvestigative       Float?    @map("ideal_riasec_investigative")
  idealRiasecArtistic            Float?    @map("ideal_riasec_artistic")
  idealRiasecSocial              Float?    @map("ideal_riasec_social")
  idealRiasecEnterprising        Float?    @map("ideal_riasec_enterprising")
  idealRiasecConventional        Float?    @map("ideal_riasec_conventional")
  motivationQuestions            Json      @default("[]") @map("motivation_questions")

  company      ImportedCompany @relation(fields: [companyId], references: [id])
  beruf        Beruf           @relation(fields: [berufCode], references: [code])
  berufsschule Berufsschule?   @relation(fields: [berufsschuleId], references: [id])

  @@index([companyId])
  @@index([berufCode])
  @@index([canton])
  @@index([status])
  @@map("lehrstellen")
}

model Berufsschule {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  canton              String
  city                String
  address             String?
  postalCode          String?  @map("postal_code")
  lat                 Float?
  lng                 Float?
  website             String?
  createdAt           DateTime @default(now()) @map("created_at")
  rbsId               String?  @unique @map("rbs_id")
  bsxId               String?  @map("bsx_id")
  echId               String?  @map("ech_id")
  email               String?
  phone               String?
  institutionalStatus String?  @map("institutional_status")

  lehrstellen   Lehrstelle[]
  berufMappings BerufsschuleBerufMapping[]

  @@map("berufsschulen")
}

model BerufsschuleBerufMapping {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  berufsschuleId String   @map("berufsschule_id") @db.Uuid
  berufCode      String   @map("beruf_code")
  canton         String
  createdAt      DateTime @default(now()) @map("created_at")

  berufsschule Berufsschule @relation(fields: [berufsschuleId], references: [id], onDelete: Cascade)
  beruf        Beruf        @relation(fields: [berufCode], references: [code], onDelete: Cascade)

  @@unique([berufsschuleId, berufCode])
  @@index([berufsschuleId])
  @@index([berufCode])
  @@index([canton])
  @@map("berufsschule_beruf_mapping")
}

model StudentFavoriteBeruf {
  studentProfileId String @map("student_profile_id")
  berufCode        String @map("beruf_code")

  student StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  beruf   Beruf          @relation(fields: [berufCode], references: [code], onDelete: Cascade)

  @@id([studentProfileId, berufCode])
  @@map("student_favorite_berufe")
}
